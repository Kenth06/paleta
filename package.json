{
  "name": "paleta-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Steal palettes from images at the edge.",
  "type": "module",
  "license": "MIT",
  "author": "Kenneth Rios",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kenth06/paleta.git"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "bench": "vitest bench",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250628.0",
    "@paleta/cache-do": "workspace:*",
    "@paleta/core": "workspace:*",
    "@paleta/exif": "workspace:*",
    "@paleta/jsquash": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "tsup": "^8.3.5"
  },
  "packageManager": "pnpm@9.15.0"
}
