{
  "name": "@ken0106/cache-do",
  "version": "0.1.0-alpha.0",
  "description": "Durable Object SQLite cache backend for paleta. Free-tier compatible.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ken0106/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250628.0"
  },
  "keywords": [
    "paleta",
    "cache",
    "durable-object",
    "durable-objects",
    "sqlite",
    "cross-colo",
    "palette",
    "color-cache",
    "cloudflare",
    "workers"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kenth06/paleta.git",
    "directory": "packages/cache-do"
  }
}
