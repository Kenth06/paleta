{
  "name": "@paleta/jsquash",
  "version": "0.1.0-alpha.0",
  "description": "jSquash decoder adapters for @paleta/core. Dynamic WASM loading, optional peers.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jpeg": {
      "types": "./dist/jpeg.d.ts",
      "import": "./dist/jpeg.js"
    },
    "./png": {
      "types": "./dist/png.d.ts",
      "import": "./dist/png.js"
    },
    "./webp": {
      "types": "./dist/webp.d.ts",
      "import": "./dist/webp.js"
    },
    "./avif": {
      "types": "./dist/avif.d.ts",
      "import": "./dist/avif.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paleta/core": "workspace:*"
  },
  "peerDependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.0",
    "@jsquash/webp": "^1.5.0",
    "@jsquash/avif": "^2.1.0"
  },
  "peerDependenciesMeta": {
    "@jsquash/jpeg": { "optional": true },
    "@jsquash/png": { "optional": true },
    "@jsquash/webp": { "optional": true },
    "@jsquash/avif": { "optional": true }
  },
  "keywords": ["jsquash", "wasm", "decode", "paleta"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kenth06/paleta.git",
    "directory": "packages/jsquash"
  }
}
